DAYTONA_API_URL=http://localhost:3000/api
DAYTONA_API_KEY=<get from http://localhost:3000 dashboard>

# Company IMLLM gateway — used inside sandboxes instead of direct Anthropic API
ANTHROPIC_BASE_URL=https://imllm.intermesh.net
ANTHROPIC_AUTH_TOKEN=<your-imllm-api-key>

# Optional
DAYTONA_OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: override snapshot name for test_snapshot.py
# SNAPSHOT_NAME=company-claude-v1
